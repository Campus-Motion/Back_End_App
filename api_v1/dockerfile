# ── Stage 1: Build ──────────────────────────────────────
FROM node:22-alpine AS builder
# Use 22 (LTS) over 20 for better patch coverage

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# ── Stage 2: Production deps only ───────────────────────
FROM node:22-alpine AS deps

WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev

# ── Stage 3: Distroless final image ─────────────────────
FROM gcr.io/distroless/nodejs22-debian12

WORKDIR /app

COPY --from=deps    /app/node_modules ./node_modules
COPY --from=builder /app/dist         ./dist

EXPOSE 3000

# Exec form, no "node" keyword, no shell
CMD ["dist/main.js"]
